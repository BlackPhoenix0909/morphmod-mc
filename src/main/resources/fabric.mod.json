  "authors": ["MorphMod"],
  "contact": {},
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main":   ["com.morphmod.MorphMod"],
    "client": ["com.morphmod.client.MorphModClient"]
  },
  "mixins": [
    "morphmod.mixins.json",
    "morphmod.client.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.15.0",
    "fabric-api": "*",
    "minecraft": "~1.20.4"
  }
}
